{
  "name": "@understand-anything/core",
  "version": "1.0.0",
  "description": "Core analysis engine for Understand-Anything",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./search": {
      "import": "./dist/search/index.js",
      "types": "./dist/search/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "web-tree-sitter": "^0.24.0",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-typescript": "^0.23.0",
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-rust": "^0.23.0",
    "tree-sitter-java": "^0.23.0",
    "tree-sitter-c": "^0.23.0",
    "tree-sitter-cpp": "^0.23.0",
    "tree-sitter-c-sharp": "^0.23.0",
    "tree-sitter-php": "^0.23.0",
    "tree-sitter-ruby": "^0.23.0",
    "tree-sitter-json": "^0.24.0",
    "tree-sitter-yaml": "^0.6.0",
    "tree-sitter-markdown": "^0.3.0",
    "tree-sitter-html": "^0.23.0",
    "tree-sitter-css": "^0.23.0",
    "fuse.js": "^7.0.0",
    "zod": "^3.23.0",
    "yaml": "^2.6.0",
    "glob": "^11.0.0",
    "ignore": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
